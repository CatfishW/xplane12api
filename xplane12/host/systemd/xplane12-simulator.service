[Unit]
Description=X-Plane 12 simulator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=tang
EnvironmentFile=-/home/tang/xplane12.env
ExecStart=/home/tang/xplane12_launch.sh
Restart=always
RestartSec=10
Environment=HOME=/home/tang
WorkingDirectory=/home/tang

[Install]
WantedBy=multi-user.target
