[Unit]
Description=X-Plane TCP reverse tunnel on port 49013
After=network-online.target xplane12-simulator.service
Wants=network-online.target
Requires=xplane12-simulator.service

[Service]
Type=simple
User=tang
EnvironmentFile=-/home/tang/xplane12.env
ExecStart=/home/tang/tunnel_xplane_49013.sh
Restart=always
RestartSec=5
Environment=HOME=/home/tang
WorkingDirectory=/home/tang

[Install]
WantedBy=multi-user.target
