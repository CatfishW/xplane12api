# Copy to /home/your-user/xplane12.env on your host and edit as needed.
# systemd units and wrapper scripts load this file automatically.
# Replace your-user with the account that owns the deployment.

# X-Plane install path
# Example Steam install path for a Linux user account.
XPLANE_HOME="/home/your-user/.steam/debian-installation/steamapps/common/X-Plane 12"
XPLANE_BIN=/usr/games/steam
XPLANE_ARGS="-silent -applaunch 2014780"
XPLANE_AIRCRAFT_PATH="Aircraft/Laminar Research/Sikorsky S-76/S-76C.acf"
DISPLAY=:1
XAUTHORITY=/run/user/1000/gdm/Xauthority
XDG_RUNTIME_DIR=/run/user/1000
DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

# Python/runtime paths
# Example checkout location on the host.
REPO_ROOT=/home/your-user/Development
PYTHON_BIN=/usr/bin/python3
XPLANE_IMAGE_EXPORT_DIR=/home/your-user/Development/.runtime/xplane12_images

# XP12 Web API
API_BASE_URL=http://127.0.0.1:8086/api/v3
# The stock Sikorsky S-76 is the preferred helicopter on XP12.4.0+ because its X530 can show native traffic and weather pages.
# If the sim's Web API is hosted elsewhere, also pass e.g.:
# AUTOFLIGHT_EXTRA_ARGS=--xplane-command '/home/your-user/X-Plane 12/X-Plane-x86_64'

# Local bridge API / stream listener
API_BIND_HOST=127.0.0.1
API_BIND_PORT=12678
STREAM_HOST=127.0.0.1
STREAM_PORT=37212

# Endless-flight relay settings
RELAY_MODE=rref
LISTEN_HOST=127.0.0.1
LISTEN_PORT=37211
TARGET_ALTITUDE_FT=8500
TARGET_HEADING_DEG=90
TARGET_SPEED_KT=160
RECOVERY_ALTITUDE_FT=4500
XPLANE_HOST=127.0.0.1
XPLANE_PORT=49009
XPLANE_UDP_PORT=49000
RREF_LISTEN_HOST=0.0.0.0
RREF_LISTEN_PORT=49004
RREF_FREQUENCY_HZ=10
RREF_SAMPLE_TIMEOUT_SECONDS=1.25
TRAFFIC_SLOTS=5
AUTOFLIGHT_EXTRA_ARGS=

# Reverse SSH tunnel settings
# Set these to the user/host that will receive the reverse tunnel.
TUNNEL_REMOTE_USER=your-user
TUNNEL_REMOTE_HOST=your-public-host
TUNNEL_RECONNECT_DELAY=5
API_TUNNEL_REMOTE_PORT=12678
XPLANE_TUNNEL_PORT=49013
XPLANE_UDP_TUNNEL_TARGET_PORT=49013

# Optional diagnostics tuning
XPLANE_DIAG_LOG_LINES=80

# Optional installer health check override
REMOTE_API_HEALTH_URL=http://127.0.0.1:12678/health
